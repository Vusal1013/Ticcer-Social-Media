# Supabase configuration (optional - currently hardcoded in src/lib/supabase.ts)
# These keys are public/client-side by design (secured via RLS)
# Get them from your Supabase project dashboard: Settings → API
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key

# OneSignal (for push notifications via Supabase Edge Functions)
# ONE_SIGNAL_APP_ID=your_app_id
# ONE_SIGNAL_API_KEY=your_api_key
