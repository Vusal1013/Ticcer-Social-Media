{
  "expo": {
    "name": "Ticcer",
    "slug": "ticcer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0F0F23"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ticcer.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Ticcer foto ve video cekmek ucun kameraya ehtiyac duyur",
        "NSPhotoLibraryUsageDescription": "Ticcer sekil yuklemek ucun galeriyaya ehtiyac duyur"
      }
    },
    "android": {
      "package": "com.ticcer.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#0F0F23",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-audio",
      "expo-image-picker",
      "expo-camera",
      "expo-notifications",
      "expo-video",
      [
        "expo-build-properties",
        {
          "android": {
            "googleServicesFile": "./google-services.json"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "0127e52f-7baf-4876-a504-fa9bedbe210f"
      }
    }
  }
}
